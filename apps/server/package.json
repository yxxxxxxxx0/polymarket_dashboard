{
  "name": "@polymarket-dashboard/server",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "PORT=4000 tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "DATABASE_URL=${DATABASE_URL:-file:./dev.db} prisma migrate dev --name init"
  },
  "dependencies": {
    "@polymarket/clob-client-v2": "^1.0.6",
    "@prisma/client": "^6.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "viem": "^2.30.6",
    "ws": "^8.18.2",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.29",
    "@types/ws": "^8.18.1",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
