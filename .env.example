PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
DEPOSIT_WALLET_ADDRESS=

# 0 = direct EOA. 1 = legacy Polymarket proxy wallet. 2 = Gnosis safe.
# 3 = EIP-1271 / Polymarket deposit wallet; use this if the CLOB balance is zero with type 1.
SIGNATURE_TYPE=3
BALANCE_SIGNATURE_TYPE=3
ORDER_SIGNATURE_TYPE=3
ENABLE_LIVE_TRADING=true

DATABASE_URL=file:/Users/justincheng/polymarket_data/dev.db
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_WS_HOST=wss://ws-subscriptions-clob.polymarket.com
POLYMARKET_DATA_HOST=https://data-api.polymarket.com
ORDERBOOK_REFRESH_MS=500
RULE_EVALUATION_MS=1000
ORDERBOOK_STALE_MS=1500
MARKET_STATS_REFRESH_MS=5000

PORT=4000
WEB_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# Leave blank to route browser requests through the Next.js /api proxy.
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_API_TIMEOUT_MS=10000
NEXT_PUBLIC_STREAM_BASE=http://localhost:4000
NEXT_PUBLIC_ORDERBOOK_POLL_MS=1000
NEXT_PUBLIC_UI_REFRESH_MS=10000
APP_TIMEZONE=Asia/Hong_Kong
GEO_COUNTRY_OVERRIDE=HK
GEO_REGION_OVERRIDE=HK
