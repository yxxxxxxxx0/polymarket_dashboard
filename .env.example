# 0 = direct EOA. 1 = legacy Polymarket proxy wallet. 2 = Gnosis safe.
# 3 = EIP-1271 / Polymarket deposit wallet; use this if the CLOB balance is zero with type 1.
SIGNATURE_TYPE=3
BALANCE_SIGNATURE_TYPE=3
ORDER_SIGNATURE_TYPE=3
ENABLE_LIVE_TRADING=true

DATABASE_URL=file:/Users/justincheng/polymarket_data/dev.db
POLYMARKET_CLOB_HOST=https://clob.polymarket.com
POLYMARKET_WS_HOST=wss://ws-subscriptions-clob.polymarket.com
POLYMARKET_DATA_HOST=https://data-api.polymarket.com
ORDERBOOK_REFRESH_MS=1000
RULE_EVALUATION_MS=1000
STOP_LOSS_POLL_MS=500
BREAKOUT_POLL_MS=1000
ORDERBOOK_STALE_MS=3000
ORDERBOOK_STALE_MS_NORMAL=1000
ORDERBOOK_STALE_MS_FAST=500
ORDERBOOK_STALE_MS_EMERGENCY=250
MAX_RULE_EVAL_MS=2500
MAX_FULL_TICK_MS=3000
STOP_LOSS_RULE_CONCURRENCY=4
